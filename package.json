{
  "name": "log-tidy",
  "version": "0.3.1",
  "description": "Lightweight log normalizer for mixed JSON/NDJSON streams.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "npm run build && node --test test/*.test.mjs",
    "lint": "tsc -p . --noEmit"
  },
  "keywords": ["logs", "json", "ndjson", "observability"],
  "author": "log-tidy contributors",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^9.0.0",
    "is-number": "7.0.0"
  }
}
